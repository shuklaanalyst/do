function bindSettings(){
  document.querySelectorAll('[data-stab]').forEach(t=>t.addEventListener('click',()=>{ S.stTab=t.dataset.stab; P(); render(); }));

  // Live preview bindings
  el('cfg-name')?.addEventListener('input',e=>{ const p=el('name-prev'); if(p) p.textContent=e.target.value||'Sales Portal'; });
  el('cfg-tag')?.addEventListener('input',e=>{ const p=el('tag-prev'); if(p) p.textContent=e.target.value||'Secondary Sales Mgmt'; });

  // Color label updates
  ['th-pr','th-ac','th-ok','th-er'].forEach(id=>{ el(id)?.addEventListener('input',e=>{ const l=el(id+'-lbl'); if(l) l.textContent=e.target.value; }); });

  // Save branding
  el('save-branding')?.addEventListener('click',()=>{
    const st=cfg();
    st.portalName=val('cfg-name').trim()||'Sales Portal';
    st.portalTagline=val('cfg-tag').trim()||'Secondary Sales Mgmt';
    st.logoEmoji=val('cfg-emoji')||'📊';
