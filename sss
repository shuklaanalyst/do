function renderBSRow(x,ym,n,visCh,LS,LW){
  LS=LS||[0,32,142]; LW=LW||[32,110,100];
  const k=sk(x.ec,ym), entry=S.sales[k]; if(!entry) return '';
  const locked=isSalesLocked(x.ec,ym);
  const gV=(c,p)=>entry.ch[c]?entry.ch[c][p]||0:0;
  const se=x.ec.replace(/[^a-z0-9]/gi,'_');
  const PRODS=getProds();
  const dbm=S.parties.find(p=>p.hq===x.hq)?.dbm||'—';
  const rowBg=n%2===0?'#f4f7fb':'#fff';
  const fcSt='position:sticky;z-index:2;border-bottom:1px solid #e2e8f0;padding:5px 8px;font-size:11.5px;white-space:nowrap;box-sizing:border-box';
  let cells='';
  visCh.forEach(c=>PRODS.forEach(p=>{
    const v=gV(c,p);
    cells+=`<td style="padding:2px 3px;border-right:1px solid #e5e7eb;border-bottom:1px solid #e5e7eb"><input type="number" min="0" class="as-inp" data-ec="${x.ec}" data-ch="${encodeURIComponent(c)}" data-p="${p}" value="${v||''}" placeholder="" ${locked?'disabled':''}></td>`;
  }));
  PRODS.forEach(p=>{ const t=getChannels().reduce((s,c)=>s+gV(c,p),0); cells+=`<td class="totc" id="at-${se}-${p}">${t||''}</td>`; });
  const grand=getChannels().reduce((s,c)=>s+PRODS.reduce((ss,p)=>ss+gV(c,p),0),0);
  cells+=`<td class="totc fw7" id="ag-${se}">${grand||''}</td>`;
