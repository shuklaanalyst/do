    return `<tr>
      <td style="${fcSt};left:${LS[0]}px;min-width:${LW[0]}px;background:#f0f4fa;text-align:center;color:#64748b;border-right:1px solid #cbd5e1">${i+1}${locked?' 🔒':''}</td>
      <td style="${fcSt};left:${LS[1]}px;min-width:${LW[1]}px;background:${rowBg};font-weight:700"><b>${x.hq}</b></td>
      <td style="${fcSt};left:${LS[2]}px;min-width:${LW[2]}px;background:${rowBg};color:#065f46;font-size:11.5px">${dbm}</td>
      <td style="${fcSt};left:${LS[3]}px;min-width:${LW[3]}px;background:${rowBg};text-align:center;border-right:2px solid #cbd5e1"><span style="display:inline-block;padding:2px 7px;border-radius:3px;background:${stBg};color:${stCol};font-size:10.5px;font-weight:700">${st==='—'?'—':st.charAt(0).toUpperCase()+st.slice(1)}</span></td>
      ${cells}
    </tr>`;
  }).join('');

  // Grand total row
  const totals={}; PRODS.forEach(p=>totals[p]=0);
  users.forEach(x=>{ const e=S.sales[sk(x.ec,ym)]; if(e) getChannels().forEach(c=>PRODS.forEach(p=>totals[p]+=(e.ch[c][p]||0))); });
  const grandTotal=Object.values(totals).reduce((s,v)=>s+v,0);
  let totalCells='';
  getChannels().forEach(c=>PRODS.forEach(p=>{
    const t=users.reduce((s,x)=>{ const e=S.sales[sk(x.ec,ym)]; return s+(e&&e.ch[c]?e.ch[c][p]||0:0); },0);
    totalCells+=`<td style="background:#1e3a8a;color:#fff;font-weight:700;text-align:right;padding:6px 8px;border-right:1px solid #2d4fa0;font-size:12px">${t||''}</td>`;
  }));
  PRODS.forEach(p=>totalCells+=`<td style="background:#713f12;color:#fff;font-weight:800;text-align:right;padding:6px 8px;border-right:1px solid #92400e;font-size:12px">${totals[p]||''}</td>`);
  totalCells+=`<td style="background:#1e3a8a;color:#fff;font-weight:800;text-align:right;padding:6px 8px;font-size:13px">${grandTotal||''}</td>`;

  return `
  <div class="card" style="overflow:hidden"><div class="xw h520">
  <table style="border-collapse:separate;border-spacing:0;font-size:12px;white-space:nowrap">
    <thead>
      <!-- ROW 1: frozen at top:0 -->
      <tr>
        <th style="${th1s};position:sticky;top:0;left:${LS[0]}px;min-width:${LW[0]}px;z-index:9" rowspan="2">#</th>
        <th style="${th1s};position:sticky;top:0;left:${LS[1]}px;min-width:${LW[1]}px;z-index:9;text-align:left" rowspan="2">HQ</th>
        <th style="${th1s};position:sticky;top:0;left:${LS[2]}px;min-width:${LW[2]}px;z-index:9;text-align:left;background:#065f46" rowspan="2">DBM HQ</th>
        <th style="${th1s};position:sticky;top:0;left:${LS[3]}px;min-width:${LW[3]}px;z-index:9;border-right:2px solid #374151" rowspan="2">Status</th>
        ${getChannels().map((c,ci)=>`<th style="${th1s};background:${['#1e3a8a','#166534','#831843'][ci]};z-index:5" colspan="${PRODS.length}">${c}</th>`).join('')}
        <th style="${th1s};background:#713f12;z-index:5" colspan="${PRODS.length}">Product Total</th>
        <th style="${th1s};background:#374151;z-index:5;min-width:56px" rowspan="2">Grand Total</th>
      </tr>
      <!-- ROW 2: frozen at top:28px -->
      <tr>
        ${getChannels().map((_,ci)=>PRODS.map(p=>`<th style="position:sticky;top:28px;z-index:4;min-width:58px;background:${['#dbeafe','#bbf7d0','#fbcfe8'][ci]};padding:4px 6px;font-size:10.5px;font-weight:700;text-align:center;border-right:1px solid #e2e8f0;border-bottom:1px solid #93c5fd">${p}</th>`).join('')).join('')}
        ${PRODS.map(p=>`<th style="position:sticky;top:28px;z-index:4;min-width:58px;background:#fef9c3;padding:4px 6px;font-size:10.5px;font-weight:700;text-align:center;border-right:1px solid #e2e8f0;border-bottom:1px solid #93c5fd">${p}</th>`).join('')}
      </tr>
    </thead>
    <tbody>
      ${rows||`<tr><td colspan="50" style="text-align:center;padding:32px;color:#94a3b8">No data for ${fmtYM(ym)}</td></tr>`}
      <tr>
        <td style="position:sticky;left:${LS[0]}px;background:#1e3a8a;color:#fff;font-weight:700;padding:6px 8px;border-right:1px solid #2d4fa0;text-align:center;z-index:2">∑</td>
        <td style="position:sticky;left:${LS[1]}px;background:#1e3a8a;color:#fff;font-weight:700;padding:6px 8px;border-right:1px solid #2d4fa0;z-index:2;font-size:11px">TOTAL</td>
        <td style="position:sticky;left:${LS[2]}px;background:#1e3a8a;color:#fff;font-weight:700;padding:6px 8px;border-right:1px solid #2d4fa0;z-index:2"></td>
        <td style="position:sticky;left:${LS[3]}px;background:#1e3a8a;color:#fff;font-weight:700;padding:6px 8px;border-right:2px solid #374151;z-index:2"></td>
        ${totalCells}
      </tr>
    </tbody>
  </table></div></div>`;
}
function bindReports(){
  document.querySelectorAll('[data-rt]').forEach(t=>t.addEventListener('click',()=>{ S.rTab=t.dataset.rt; const ym=`${S.rptY||new Date().getFullYear()}-${S.rptM||String(new Date().getMonth()+1).padStart(2,'0')}`; el('rpt-con').innerHTML=renderRptCon(S.rTab,getMyHQUsers(S.cu),ym); }));
  el('rpt-ok')?.addEventListener('click',()=>{ S.rptY=val('rpt-yr'); S.rptM=val('rpt-mo'); render(); });
  el('rpt-exp')?.addEventListener('click',()=>{
    const u=S.cu, users=getMyHQUsers(u);
    const ym=`${S.rptY||new Date().getFullYear()}-${S.rptM||String(new Date().getMonth()+1).padStart(2,'0')}`;
    const at=S.rTab||'hq';
    const wb=XLSX.utils.book_new();
    const PRODS=getProds();

    if(at==='sales'){
      // Exact clone of Sales (All Channels) tab
      const hdr=['#','HQ','DBM HQ','Status',...getChannels().flatMap(c=>PRODS.map(p=>c+' — '+p)),...PRODS.map(p=>'Total — '+p),'Grand Total'];
      const data=[hdr];
      users.forEach((x,i)=>{
        const e=S.sales[sk(x.ec,ym)]; const gV=(c,p)=>e&&e.ch[c]?e.ch[c][p]||0:0;
        const dbm=S.parties.find(p=>p.hq===x.hq)?.dbm||'—';
        const st=e?e.status:'—';
        const row=[i+1,x.hq,dbm,st];
        getChannels().forEach(c=>PRODS.forEach(p=>row.push(gV(c,p)||'')));
        PRODS.forEach(p=>row.push(getChannels().reduce((s,c)=>s+gV(c,p),0)||''));
        row.push(getChannels().reduce((s,c)=>s+PRODS.reduce((ss,p)=>ss+gV(c,p),0),0)||'');
        data.push(row);
      });
      // Total row
      const totRow=['','TOTAL','',''];
      getChannels().forEach(c=>PRODS.forEach(p=>totRow.push(users.reduce((s,x)=>{ const e=S.sales[sk(x.ec,ym)]; return s+(e&&e.ch[c]?e.ch[c][p]||0:0); },0)||'')));
      const ptot={}; PRODS.forEach(p=>ptot[p]=0); users.forEach(x=>{ const e=S.sales[sk(x.ec,ym)]; if(e) getChannels().forEach(c=>PRODS.forEach(p=>ptot[p]+=(e.ch[c][p]||0))); });
      PRODS.forEach(p=>totRow.push(ptot[p]||''));
      totRow.push(Object.values(ptot).reduce((s,v)=>s+v,0)||'');
      data.push(totRow);
      const ws=XLSX.utils.aoa_to_sheet(data);
      XLSX.utils.book_append_sheet(wb,ws,'Sales - All Channels');
    } else if(at==='hq'){
      const hdr=['HQ','Manager',...PRODS,'Total','Status']; const rows=[hdr];
      users.forEach(u=>{ const e=S.sales[sk(u.ec,ym)]; const tots={}; PRODS.forEach(p=>tots[p]=0); if(e) getChannels().forEach(c=>PRODS.forEach(p=>tots[p]+=(e.ch[c][p]||0))); const mgr=getMgrForHQ(u.hq).map(m=>m.name).join(', ')||'—'; rows.push([u.hq,mgr,...PRODS.map(p=>tots[p]||''),Object.values(tots).reduce((s,v)=>s+v,0)||'',e?e.status:'not started']); });
      XLSX.utils.book_append_sheet(wb,XLSX.utils.aoa_to_sheet(rows),'HQ-wise');
    } else if(at==='user'){
      const hdr=['Login ID','HQ',...PRODS,'Total','Status']; const rows=[hdr];
      users.forEach(u=>{ const e=S.sales[sk(u.ec,ym)]; const tots={}; PRODS.forEach(p=>tots[p]=0); if(e) getChannels().forEach(c=>PRODS.forEach(p=>tots[p]+=(e.ch[c][p]||0))); rows.push([u.ec,u.hq,...PRODS.map(p=>tots[p]||''),Object.values(tots).reduce((s,v)=>s+v,0)||'',e?e.status:'not started']); });
      XLSX.utils.book_append_sheet(wb,XLSX.utils.aoa_to_sheet(rows),'User-wise');
    } else if(at==='mgr'){
      const hdr=['Manager','Login ID','HQs',...PRODS,'Total','Finals/Total']; const rows=[hdr];
      getAllManagers().forEach(m=>{ const tots={}; PRODS.forEach(p=>tots[p]=0); let finals=0; m.mappedHQs.forEach(hq=>{ const ux=getUserByHQ(hq); if(!ux) return; const e=S.sales[sk(ux.ec,ym)]; if(e){ getChannels().forEach(c=>PRODS.forEach(p=>tots[p]+=(e.ch[c][p]||0))); if(e.status==='final') finals++; } }); rows.push([m.name,m.ec,m.mappedHQs.length,...PRODS.map(p=>tots[p]||''),Object.values(tots).reduce((s,v)=>s+v,0)||'',finals+'/'+m.mappedHQs.length]); });
      XLSX.utils.book_append_sheet(wb,XLSX.utils.aoa_to_sheet(rows),'Manager-wise');
    } else if(at==='channel'){
      const hdr=['Channel',...PRODS,'Total']; const rows=[hdr];
      const chData={}; getChannels().forEach(c=>{ chData[c]={}; PRODS.forEach(p=>chData[c][p]=0); });
      users.forEach(ux=>{ const e=S.sales[sk(ux.ec,ym)]; if(e) getChannels().forEach(c=>PRODS.forEach(p=>chData[c][p]+=(e.ch[c][p]||0))); });
      getChannels().forEach(c=>rows.push([c,...PRODS.map(p=>chData[c][p]||''),Object.values(chData[c]).reduce((s,v)=>s+v,0)||'']));
      const gt=[]; PRODS.forEach(p=>gt.push(getChannels().reduce((s,c)=>s+chData[c][p],0)||''));
      rows.push(['Grand Total',...gt,gt.reduce((s,v)=>s+(v||0),0)||'']);
      XLSX.utils.book_append_sheet(wb,XLSX.utils.aoa_to_sheet(rows),'Channel-wise');
    }
    XLSX.writeFile(wb,'Sales_Report_'+ym+'_'+at+'.xlsx');
  });
}

