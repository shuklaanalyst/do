    }));
    PRODS.forEach(p=>{ const t=getChannels().reduce((s,c)=>s+gV(c,p),0); cells+=`<td style="background:#fefce8;font-weight:700;text-align:right;padding:5px 8px;border-right:1px solid #e5e7eb;border-bottom:1px solid #e5e7eb;font-size:12px">${t||''}</td>`; });
    const grand=getChannels().reduce((s,c)=>s+PRODS.reduce((ss,p)=>ss+gV(c,p),0),0);
