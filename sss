function bindLogin(){
  const go=()=>{
    const id=el('lid')?.value.trim()||'', pw=el('lpw')?.value||'';
    const u=S.users.find(u=>u.ec===id&&u.pw===pw&&u.status==='Active');
    if(!u){ el('lerr').style.display='block'; el('lerr-msg').textContent='Invalid Login ID or Password.'; return; }
    el('lerr').style.display='none';
    S.cu=u; S.tab=u.role==='admin'?'dash':u.role==='manager'?'mgr-dash':'prof'; P(); render();
  };
  el('lbtn')?.addEventListener('click',go);
  el('lpw')?.addEventListener('keydown',e=>{ if(e.key==='Enter'){e.preventDefault();go();} });
  el('lid')?.addEventListener('keydown',e=>{ if(e.key==='Enter'){e.preventDefault();el('lpw')?.focus();} });
