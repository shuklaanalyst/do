function closeModal(id){ el(id)?.remove(); }
function showConfirm(title,body,type,cb){
  const mc=el('mc'); if(!mc) return;
  mc.innerHTML=`<div class="mov" id="cfm"><div class="mo" style="max-width:400px">
    <div class="mo-hd"><span class="mo-ttl">${title}</span></div>
    <div class="mo-bd tc" style="padding:24px 28px"><div style="font-size:36px;margin-bottom:12px">${type==='wa'?'⚠️':'🗑️'}</div>
    <div style="color:var(--tm);font-size:13.5px;line-height:1.7">${body}</div></div>
    <div class="mo-ft"><button class="btn b-gh b-sm" onclick="closeModal('cfm')">Cancel</button>
    <button class="btn ${type==='wa'?'b-wa':'b-er'} b-sm" id="cfm-ok">Confirm</button></div>
  </div></div>`;
  el('cfm-ok')?.addEventListener('click',()=>{ closeModal('cfm'); cb(); });
}
function toast(msg,type='ok'){
  const t=document.createElement('div');
  t.style.cssText=`position:fixed;bottom:20px;right:20px;background:${type==='ok'?'var(--ok)':'var(--er)'};color:#fff;padding:9px 16px;border-radius:7px;font-weight:600;font-size:13px;z-index:9999;box-shadow:var(--s2);animation:tIn .2s ease;`;
  t.textContent=(type==='ok'?'✓ ':'✗ ')+msg;
  document.body.appendChild(t);
  if(!el('tAnim')){ const s=document.createElement('style'); s.id='tAnim'; s.textContent='@keyframes tIn{from{transform:translateY(16px);opacity:0}to{transform:none;opacity:1}}'; document.head.appendChild(s); }
  setTimeout(()=>{ t.style.transition='opacity .3s'; t.style.opacity='0'; setTimeout(()=>t.remove(),300); },2500);
}

