window.updateDBMOptions=function(){
  const dbmSel=el('p-dbm'); if(!dbmSel) return;
  // Always show ALL DBM HQs — never filter by HQ
  const allDBMs=getAllDBMHQs();
  const cur=dbmSel.value;
  dbmSel.innerHTML=`<option value="">— Select DBM HQ —</option>${allDBMs.map(d=>`<option ${d===cur?'selected':''}>${d}</option>`).join('')}${cur&&!allDBMs.includes(cur)?`<option selected>${cur}</option>`:''}`;
};

window.addNewDBM=function(){
  const newDbm=val('p-dbm-new').trim().toUpperCase();
  if(!newDbm){toast('Enter a DBM HQ name','er');return;}
  const allDBMs=getAllDBMHQs();
  if(allDBMs.includes(newDbm)){toast(`"${newDbm}" already exists in DBM HQ list`,'er');return;}
  // Save to master list permanently
  saveDBMToMaster(newDbm);
  // Add to current dropdown
  const sel=el('p-dbm'); if(!sel) return;
  const opt=document.createElement('option');
  opt.value=newDbm; opt.text=newDbm; opt.selected=true;
  sel.appendChild(opt);
  el('p-dbm-new').value='';
  toast(`✓ "${newDbm}" added to DBM HQ master list!`);
};

