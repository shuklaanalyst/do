function showAddUserModal(){
  showModal('uamod','Add User / Manager',`
  <div class="al al-i">${si('warn')} If Role Type = MANAGER, user appears in Manager Mapping tab for HQ assignment.</div>
  <div class="fr3">
    <div class="fg"><label class="fl">Role Type *</label>
      <select class="fc" id="ua-role" onchange="this.value==='MANAGER'?(el('ua-hq').disabled=true,el('ua-hq').value='',el('ua-hq-row').style.display='none',el('ua-mgr-note').style.display='block'):(el('ua-hq').disabled=false,el('ua-hq-row').style.display='',el('ua-mgr-note').style.display='none')">
        <option value="">Select Role</option>
        <option value="USER">USER — HQ Level</option>
        <option value="MANAGER">MANAGER</option>
      </select>
    </div>
    <div class="fg"><label class="fl">Employee Name *</label><input class="fc" id="ua-name" placeholder="Full name"></div>
    <div class="fg"><label class="fl">Status</label><select class="fc" id="ua-st"><option>Active</option><option>Inactive</option></select></div>
  </div>
  <div class="fr">
    <div class="fg"><label class="fl">Login ID *</label><input class="fc" id="ua-ec" placeholder="HQ name for USER, custom for MANAGER"></div>
    <div class="fg"><label class="fl">Password</label><input class="fc" id="ua-pw" placeholder="Blank = 'password'"></div>
  </div>
  <div class="fg" id="ua-hq-row"><label class="fl">HQ Name *</label><input class="fc" id="ua-hq" placeholder="Must match Login ID for USER"></div>
  <div class="al al-wa dn" id="ua-mgr-note">${si('warn')} Manager users: HQ mapping is done in Manager Mapping tab after creation.</div>
  <div class="fr">
    <div class="fg"><label class="fl">Date of Joining</label><input class="fc" type="date" id="ua-doj"></div>
    <div class="fg"><label class="fl">Date of Relieving</label><input class="fc" type="date" id="ua-dor"></div>
  </div>`,
  ()=>{
    const role=val('ua-role'), name=val('ua-name').trim(), ec=val('ua-ec').trim();
    if(!role){toast('Select a Role Type','er');return false;}
    if(!name||!ec){toast('Name and Login ID required','er');return false;}
    if(S.users.find(u=>u.ec===ec)){toast(`Login ID "${ec}" already exists — duplicates not allowed!`,'er');return false;}
    const pw=val('ua-pw').trim()||'password';
    if(role==='USER'){
      const hq=val('ua-hq').trim()||ec; // default hq = ec for user
      S.users.push({ec,name,pw,role:'user',hq,mappedHQs:[],status:val('ua-st'),doj:val('ua-doj'),dor:val('ua-dor'),pic:''});
      toast('HQ User added! Login ID = '+ec);
    } else {
      S.users.push({ec,name,pw,role:'manager',hq:'',mappedHQs:[],status:val('ua-st'),doj:val('ua-doj'),dor:val('ua-dor'),pic:''});
      toast('Manager added! Go to Manager Mapping to assign HQs.');
    }
    P(); closeModal('uamod'); render();
  });
  // Auto-fill HQ from Login ID for USER
  el('ua-ec')?.addEventListener('input',()=>{ if(val('ua-role')==='USER'&&!el('ua-hq').disabled) el('ua-hq').value=el('ua-ec').value; });
}

