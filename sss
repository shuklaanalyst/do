window.filterPartyTable=function(){
  const fhq=val('pt-fhq'), fdbm=val('pt-fdbm'), ftype=val('pt-ftype');
  const id='parties';
  const ts=getTState(id);
  const q=(ts.search||'').toLowerCase();
  const filtered=S.parties.filter(p=>{
    const matchQ=!q||(p.sname+p.hq+p.dbm+(p.ptype||'')).toLowerCase().includes(q);
    return matchQ&&(!fhq||p.hq===fhq)&&(!fdbm||p.dbm===fdbm)&&(!ftype||p.ptype===ftype);
  });
  const ps=ts.pageSize||15, page=Math.min(ts.page||1,Math.max(1,Math.ceil(filtered.length/ps)));
  const pageRows=filtered.slice((page-1)*ps,page*ps);
  const c=el('pt-tbody'); if(c) c.innerHTML=renderPartyExcelRows(pageRows);
  const pEl=el('pt-pgn'); if(pEl) pEl.innerHTML=renderPgn(id,{rows:pageRows,total:filtered.length,page,totalPages:Math.max(1,Math.ceil(filtered.length/ps)),pageSize:ps});
  const cEl=el('pt-count'); if(cEl) cEl.textContent=`${filtered.length} of ${S.parties.length} records`;
};

function renderPartyExcelRows(rows){
  if(!rows.length) return `<tr><td colspan="6" style="text-align:center;padding:56px 20px;color:#94a3b8;background:#fafbfc">
    <div style="font-size:36px;margin-bottom:10px">📋</div>
    <div style="font-weight:700;font-size:14px;color:#64748b">No records found</div>
    <div style="font-size:12px;margin-top:4px">Adjust your filters or search term</div>
  </td></tr>`;

  const GRID='1px solid #d1d9e6';
  const EVEN='#ffffff', ODD='#f4f7fb', HOV='#e8f0fe';
  const PTCOLORS={Dermis:'#dbeafe|#1e40af',Entero:'#dcfce7|#166534',eCommerce:'#fef9c3|#854d0e',MT:'#fdf4ff|#7e22ce',Other:'#f1f5f9|#475569'};

  return rows.map((p,i)=>{
    const bg=i%2===0?EVEN:ODD;
    const td=(content,align='left',extra='')=>`<td style="padding:7px 10px;border-right:${GRID};border-bottom:${GRID};text-align:${align};vertical-align:middle;${extra}">${content}</td>`;
    const [ptBg,ptCol]=(PTCOLORS[p.ptype]||'#f1f5f9|#475569').split('|');

    return `<tr style="background:${bg}" onmouseover="this.querySelectorAll('td').forEach(t=>t.style.background='${HOV}')" onmouseout="this.querySelectorAll('td').forEach(t=>t.style.background='')">
      ${td(`<span style="color:#94a3b8;font-size:11px;font-weight:600">${p.sr}</span>`,'center')}
      ${td(`<span style="font-weight:600;color:#0f172a;font-size:12.5px">${p.sname}</span>`)}
