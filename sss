/* ======================================================
   IMPORT — two-step with full validation & error log
   ====================================================== */
function showImportModal(type){
  const lbl={users:'Users & Managers',parties:'Parties','admin-sales':'Sales Data',stk:'Stockiest Data'};
  showModalLg('impmod',`Import — ${lbl[type]||type}`,`
  <div class="al al-i">${si('warn')} <b>Two-step:</b> Upload → Validate & Preview → Confirm Save. Duplicates are blocked.</div>
  <div class="al al-wa">${si('warn')} <b>For Users:</b> Role Type column = USER or MANAGER. Login ID = HQ name for USER. MANAGER entries auto-appear in Manager Mapping.</div>
  <div class="fr" style="align-items:flex-end">
    <div class="fg"><label class="fl">Select Excel File (.xlsx / .xls)</label><input type="file" id="imp-file" accept=".xlsx,.xls" class="fc" style="padding:5px 8px;cursor:pointer"></div>
    <button class="btn b-pr b-sm" id="imp-prev">${si('eye')} Upload & Validate</button>
  </div>
  <div id="imp-result" class="mt3"></div>
  <div id="imp-save-area" style="display:none;margin-top:12px;padding-top:12px;border-top:1px solid var(--bd)">
    <div id="imp-summary" class="al al-ok"></div>
    <div style="display:flex;justify-content:flex-end;gap:8px">
      <button class="btn b-gh b-sm" onclick="el('imp-save-area').style.display='none';el('imp-result').innerHTML=''">Cancel</button>
      <button class="btn b-ok b-sm" id="imp-save">${si('save')} Confirm & Save</button>
    </div>
  </div>`);
  let pending=null;
  el('imp-prev')?.addEventListener('click',()=>{
    const fi=el('imp-file'); if(!fi?.files?.length){toast('Select a file first','er');return;}
    const reader=new FileReader();
    reader.onload=ev=>{ try{
      const wb=XLSX.read(new Uint8Array(ev.target.result),{type:'array'});
      const rows=XLSX.utils.sheet_to_json(wb.Sheets[wb.SheetNames[0]],{header:1,defval:''});
      if(!rows||rows.length<2){toast('File is empty','er');return;}
      const result=validateImport(type,rows); pending=result.data;
      el('imp-result').innerHTML=renderImportPreview(type,result);
      if(result.valid.length>0){
        el('imp-save-area').style.display='block';
        el('imp-summary').innerHTML=`${si('check')} <b>${result.valid.length} valid records</b> ready to import.${result.errors.length?` <b style="color:var(--er)">${result.errors.length} rows skipped</b> (see error log).`:''} ${result.dupes.length?`<b style="color:var(--wa)">${result.dupes.length} duplicates blocked.</b>`:''}`;
        el('imp-save')?.addEventListener('click',()=>{ commitImport(type,pending); closeModal('impmod'); });
      } else { el('imp-save-area').style.display='none'; }
    }catch(e){toast(`Read error: ${e.message}`,'er');} };
    reader.readAsArrayBuffer(fi.files[0]);
  });
}
function validateImport(type,rows){
  const valid=[],errors=[],dupes=[],data=[];
  rows.slice(1).forEach((r,idx)=>{
    const rn=idx+2;
    if(type==='users'){
      const role=String(r[0]||'').trim().toUpperCase(); // col A = Role Type
      const ec=String(r[1]||'').trim();
      const hq=String(r[2]||'').trim();
      const name=String(r[3]||'').trim();
      const doj=String(r[4]||'').trim();
      const status=String(r[5]||'Active').trim();
      if(!role||!['USER','MANAGER'].includes(role)){errors.push({row:rn,msg:`Role Type "${role}" invalid. Use USER or MANAGER`});return;}
      if(!ec){errors.push({row:rn,msg:'Login ID missing'});return;}
      if(!name){errors.push({row:rn,msg:'Employee Name missing'});return;}
      if(role==='USER'&&!hq){errors.push({row:rn,msg:'HQ Name required for USER'});return;}
      // Check duplicate
      if(S.users.find(u=>u.ec===ec)){dupes.push({row:rn,ec,msg:`Login ID "${ec}" already exists`});return;}
      valid.push(r);
      if(role==='USER') data.push({ec:hq||ec,hq:hq||ec,name,pw:'password',role:'user',mappedHQs:[],status,doj,dor:'',pic:''});
      else data.push({ec,hq:'',name,pw:'password',role:'manager',mappedHQs:[],status,doj,dor:'',pic:''});
    } else if(type==='parties'){
      const sn=String(r[0]||'').trim(), hq=String(r[1]||'').trim();
      if(!sn){errors.push({row:rn,msg:'Stockist Name missing'});return;}
      if(!hq){errors.push({row:rn,msg:'HQ missing'});return;}
      valid.push(r); data.push({sname:sn,hq,dbm:String(r[2]||'').trim()});
    }
  });
  return {valid,errors,dupes,data};
}
function renderImportPreview(type,result){
  let html='';
  // Error log
  if(result.errors.length){
    html+=`<div class="al al-er">${si('warn')} <b>${result.errors.length} validation errors:</b></div>
    <ul class="err-log mt2">${result.errors.slice(0,20).map(e=>`<li>Row ${e.row}: ${e.msg}</li>`).join('')}${result.errors.length>20?`<li>...and ${result.errors.length-20} more errors</li>`:''}</ul>`;
  }
  if(result.dupes?.length){
    html+=`<div class="al al-wa mt2">${si('warn')} <b>${result.dupes.length} duplicates blocked (Login IDs already exist):</b> ${result.dupes.map(d=>`<b>${d.ec}</b>`).join(', ')}</div>`;
  }
  if(!result.valid.length){ return html+`<div class="al al-er mt2">${si('warn')} No valid rows found. Check your file format and try again.</div>`; }
  html+=`<div style="font-weight:700;font-size:12px;color:var(--tm);margin:12px 0 6px">Preview — first ${Math.min(10,result.valid.length)} of ${result.valid.length} valid rows:</div>`;
  html+=`<div style="overflow:auto;max-height:200px;border:1px solid var(--bd);border-radius:var(--rd)"><table class="prev-tbl"><thead>`;
  if(type==='users') html+=`<tr><th>Role Type</th><th>Login ID</th><th>HQ Name</th><th>Employee Name</th><th>DOJ</th><th>Status</th></tr></thead><tbody>${result.valid.slice(0,10).map(r=>`<tr><td class="${String(r[0]).trim().toUpperCase()==='MANAGER'?'c-ok':''}">${r[0]}</td><td>${r[1]}</td><td>${r[2]}</td><td>${r[3]}</td><td>${r[4]}</td><td>${r[5]||'Active'}</td></tr>`).join('')}`;
  else if(type==='parties') html+=`<tr><th>Stockist Name</th><th>HQ</th><th>DBM HQ</th></tr></thead><tbody>${result.valid.slice(0,10).map(r=>`<tr><td>${r[0]}</td><td>${r[1]}</td><td>${r[2]}</td></tr>`).join('')}`;
  html+=`</tbody></table></div>`;
  if(result.valid.length>10) html+=`<div class="ts tmu mt2">...and ${result.valid.length-10} more valid rows.</div>`;
  return html;
}
function commitImport(type,data){
  let count=0;
  data.forEach(d=>{
    if(type==='users'){
      if(!S.users.find(u=>u.ec===d.ec)){ S.users.push(d); count++; }
    } else if(type==='parties'){
      S.parties.push({id:S.pidx++,sr:S.parties.length+1,...d}); count++;
    }
  });
  P(); toast(`Saved ${count} records successfully!`); setTimeout(()=>render(),600);
}

