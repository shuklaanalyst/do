      <button class="btn b-mg b-sm" type="button" id="m-hq-add">${si('plus')} Add HQ</button>
    </div>
    <div class="chips" id="m-chips">${renderChips(window._chips)}</div>
    <div class="ts tmu mt2">${allHQs.length} HQs available • click × to remove</div>
  </div>`,
  ()=>{
    const ec=isNew?val('m-ec').trim():m.ec, name=val('m-name').trim();
    if(!ec||!name){toast('Login ID and Name required','er');return false;}
    if(isNew&&S.users.find(x=>x.ec===ec)){toast(`Login ID "${ec}" already exists`,'er');return false;}
    const pw=isNew?(val('m-pw').trim()||'password'):m.pw;
    const ud={ec,name,pw,role:'manager',hq:'',mappedHQs:[...window._chips],status:val('m-st'),doj:val('m-doj'),dor:'',pic:m?.pic||''};
    if(m){ const i=S.users.findIndex(x=>x.ec===ec); S.users[i]={...m,...ud}; if(S.cu.ec===ec) S.cu=S.users[i]; }
