/* ======================================================
   PAGINATION / SORT / SEARCH HELPER
   ====================================================== */
function getTState(id){ if(!S.tState[id]) S.tState[id]={page:1,pageSize:PAGE_SIZE,sort:'',dir:'asc',search:''}; return S.tState[id]; }
function setTState(id,k,v){ const ts=getTState(id); ts[k]=v; if(k!=='page') ts.page=1; P(); }
function applyTState(id,rows,cols){
  const ts=getTState(id);
  // Search
  let filtered=rows;
  if(ts.search){ const q=ts.search.toLowerCase(); filtered=rows.filter(r=>cols.some(c=>String(r[c]||'').toLowerCase().includes(q))); }
  // Sort
  if(ts.sort){ const si=cols.indexOf(ts.sort); filtered=[...filtered].sort((a,b)=>{ const av=String(a[ts.sort]||'').toLowerCase(), bv=String(b[ts.sort]||'').toLowerCase(); return ts.dir==='asc'?(av>bv?1:av<bv?-1:0):(av<bv?1:av>bv?-1:0); }); }
  // Paginate
  const total=filtered.length, ps=ts.pageSize||PAGE_SIZE, totalPages=Math.max(1,Math.ceil(total/ps)), page=Math.min(ts.page||1,totalPages);
  return { rows:filtered.slice((page-1)*ps,page*ps), total, page, totalPages, pageSize:ps };
}
function renderPgn(id,res){
  const {page,totalPages,total,pageSize}=res, ts=getTState(id);
  const from=(page-1)*pageSize+1, to=Math.min(page*pageSize,total);
  const pages=[];
  if(totalPages<=7){ for(let i=1;i<=totalPages;i++) pages.push(i); }
  else{ if(page<=4){ pages.push(1,2,3,4,5,'…',totalPages); } else if(page>=totalPages-3){ pages.push(1,'…',totalPages-4,totalPages-3,totalPages-2,totalPages-1,totalPages); } else { pages.push(1,'…',page-1,page,page+1,'…',totalPages); } }
  return `<div class="pgn">
    <div class="pgn-sz"><select onchange="setTState('${id}','pageSize',+this.value);rerenderTbl('${id}')" style="font-family:inherit">${[10,15,25,50].map(n=>`<option ${n===pageSize?'selected':''}>${n}</option>`).join('')}</select> / page</div>
    <span class="pgn-info">${total} records • ${from}–${to}</span>
    <div style="margin-left:auto;display:flex;gap:3px">
      <button class="pgn-btn" onclick="setTState('${id}','page',${page-1});rerenderTbl('${id}')" ${page===1?'disabled':''}>‹</button>
      ${pages.map(p=>p==='…'?`<span style="padding:0 4px;line-height:28px">…</span>`:`<button class="pgn-btn${p===page?' on':''}" onclick="setTState('${id}','page',${p});rerenderTbl('${id}')">${p}</button>`).join('')}
      <button class="pgn-btn" onclick="setTState('${id}','page',${page+1});rerenderTbl('${id}')" ${page===totalPages?'disabled':''}>›</button>
    </div>
  </div>`;
}
