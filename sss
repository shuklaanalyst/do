function bindUserMgmt(){
  document.querySelectorAll('[data-ut]').forEach(t=>t.addEventListener('click',()=>{ S.umTab=t.dataset.ut; P(); render(); }));
  document.querySelectorAll('[data-mmt]').forEach(t=>t.addEventListener('click',()=>{ S.mmTab=t.dataset.mmt; P(); render(); }));
  el('add-usr-btn')?.addEventListener('click',()=>showAddUserModal());
  el('add-mgr2-btn')?.addEventListener('click',()=>showMgrModal(null));
  el('add-mgr-btn')?.addEventListener('click',()=>showMgrModal(null));
  el('dl-tpl-btn')?.addEventListener('click',()=>dlTpl(S.umTab==='mgrs'?'mgrs':'users'));
  el('imp-btn')?.addEventListener('click',()=>showImportModal(S.umTab==='mgrs'?'mgrs':'users'));
  el('pwm-dl')?.addEventListener('click',()=>{ const wb=XLSX.utils.book_new(); const rows=[['Login ID','Role','HQ/HQs','Status'],...S.users.filter(u=>u.role!=='admin').map(u=>[u.ec,u.role,u.role==='manager'?u.mappedHQs.join(', '):u.hq,u.status])]; XLSX.utils.book_append_sheet(wb,XLSX.utils.aoa_to_sheet(rows),'Users'); XLSX.writeFile(wb,'User_List.xlsx'); });
  el('dl-mm-btn')?.addEventListener('click',()=>{
    const wb=XLSX.utils.book_new();
    const mgrs=getAllManagers(); const allHQs=getAllHQNames();
    const unmapped=allHQs.filter(h=>!mgrs.some(m=>m.mappedHQs.includes(h)));
    XLSX.utils.book_append_sheet(wb,XLSX.utils.aoa_to_sheet([['Login ID','Manager Name','Status','DOJ','Mapped HQs'],...mgrs.map(m=>[m.ec,m.name,m.status,m.doj,m.mappedHQs.join(', ')])]),'Manager Mapping');
    XLSX.utils.book_append_sheet(wb,XLSX.utils.aoa_to_sheet([['HQ Name','Parties'],...unmapped.map(h=>[h,S.parties.filter(p=>p.hq===h).length])]),'Unmapped HQs');
    XLSX.writeFile(wb,'Manager_Mapping.xlsx');
  });
  // Quick assign button handlers
  document.querySelectorAll('.qa-btn').forEach(btn=>btn.addEventListener('click',()=>{
    const hq=btn.dataset.hq, selId='qa-'+CSS.escape(hq), mec=val(selId);
    if(!mec){toast('Select a manager first','er');return;}
    const i=S.users.findIndex(u=>u.ec===mec&&u.role==='manager');
    if(i<0){toast('Manager not found','er');return;}
    if(!S.users[i].mappedHQs.includes(hq)) S.users[i].mappedHQs.push(hq);
    if(S.cu.ec===mec) S.cu=S.users[i];
    P(); render(); toast(hq+' assigned to '+S.users[i].name+'!');
  }));
}

