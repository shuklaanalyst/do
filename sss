  // Apply theme
  el('save-theme')?.addEventListener('click',()=>{
    const st=cfg();
    st.theme={primary:el('th-pr')?.value||'#1e3a8a',accent:el('th-ac')?.value||'#2563eb',ok:el('th-ok')?.value||'#16a34a',er:el('th-er')?.value||'#dc2626'};
    P(); applyTheme(); render(); toast('Theme applied!');
  });
  el('reset-theme')?.addEventListener('click',()=>{
    cfg().theme={primary:'#1e3a8a',accent:'#2563eb',ok:'#16a34a',er:'#dc2626'};
    P(); applyTheme(); render(); toast('Theme reset to default!');
  });

  // Menu toggles
  el('show-all-menus')?.addEventListener('click',()=>{ cfg().hiddenMenus=[]; P(); render(); });
  el('hide-all-menus')?.addEventListener('click',()=>{ cfg().hiddenMenus=MENU_ITEMS.map(m=>m.k); P(); render(); });
  el('save-menus')?.addEventListener('click',()=>{
    cfg().hiddenMenus=MENU_ITEMS.filter(m=>!el('mn-'+m.k)?.checked).map(m=>m.k);
    P(); render(); toast('Menu settings saved!');
  });

  // Sub-admin
  el('add-sa-btn')?.addEventListener('click',()=>showSubAdminModal(null));
  document.querySelectorAll('.qa-btn').forEach(btn=>btn.addEventListener('click',()=>{
    const hq=btn.dataset.hq, mec=val('qa-'+CSS.escape(hq));
    if(!mec){toast('Select a manager first','er');return;}
    const i=S.users.findIndex(u=>u.ec===mec&&u.role==='manager');
    if(i<0) return;
    if(!S.users[i].mappedHQs.includes(hq)) S.users[i].mappedHQs.push(hq);
    if(S.cu.ec===mec) S.cu=S.users[i];
    P(); render(); toast(hq+' assigned!');
  }));
}

function applyTheme(){
  const th=cfg().theme||{};
  const r=document.documentElement.style;
  if(th.primary) r.setProperty('--pr',th.primary);
  if(th.accent) { r.setProperty('--pm',th.accent); r.setProperty('--ac',th.accent); }
  if(th.ok) r.setProperty('--ok',th.ok);
  if(th.er) r.setProperty('--er',th.er);
}

